{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"types": ["node", "electron"],
		"baseUrl": ".",
		"paths": {
			"@renderer/*": ["src/renderer/*"],
			"@shared/*": ["src/shared/*"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "postcss.config.cjs", "tailwind.config.cjs"],
	"exclude": ["node_modules", "dist"]
}

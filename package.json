{
	"name": "morpho",
	"version": "1.0.0",
	"description": "Morpho Amazon Music desktop replacement shell",
	"author": "Enazzzz",
	"license": "MIT",
	"main": "dist/main/main.js",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Enazzzz/AMAZING-MUSIC.git"
	},
	"scripts": {
		"build": "npm run clean && npm run build:main && npm run build:renderer",
		"build:main": "tsc -p tsconfig.main.json",
		"build:renderer": "vite build",
		"clean": "rimraf dist",
		"dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
		"dev:renderer": "vite",
		"dev:electron": "wait-on tcp:5173 && npm run build:main && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
		"launcher:dev": "npm run build:main && node dist/launcher/worker.js",
		"inject:extension": "npm run build:main && node dist/launcher/injectExtension.js",
		"server:only": "npm run build:main && cross-env MORPHO_SERVER_ONLY=1 electron .",
		"fake:host": "npm run build:main && node dist/launcher/fakeGroupHost.js",
		"probe:audio-path": "npm run build:main && node dist/launcher/audioPathProbe.js",
		"recon:home-network": "npm run build:main && node dist/launcher/reconHomeNetwork.js",
		"scan:decode-modules": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/scan-decode-modules.ps1",
		"recon:audio-pipeline": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-audio-pipeline-recon.ps1",
		"start": "npm run build && electron .",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"package": "npm run build && electron-builder"
	},
	"dependencies": {
		"electron-store": "^11.0.2",
		"fast-average-color": "^9.5.0",
		"framer-motion": "^12.23.24",
		"node-window-manager": "^2.2.4",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"ws": "^8.18.3",
		"zustand": "^5.0.8"
	},
	"devDependencies": {
		"@types/node": "^24.5.2",
		"@types/react": "^18.3.24",
		"@types/react-dom": "^18.3.7",
		"@types/ws": "^8.18.1",
		"@vitejs/plugin-react": "^5.0.2",
		"autoprefixer": "^10.4.21",
		"concurrently": "^9.2.1",
		"cross-env": "^10.0.0",
		"electron": "^41.0.2",
		"electron-builder": "^26.0.12",
		"postcss": "^8.5.6",
		"rimraf": "^6.0.1",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.9.3",
		"vite": "^7.1.7",
		"vitest": "^4.1.0",
		"wait-on": "^8.0.5"
	},
	"build": {
		"appId": "com.morpho.desktop",
		"productName": "Morpho",
		"files": [
			"dist/**/*",
			"package.json"
		],
		"directories": {
			"buildResources": "assets"
		},
		"win": {
			"target": "nsis"
		}
	}
}
